generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  ARCHITECT
  CUSTOMER
  TERRAIN_OWNER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ArchitectStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum TerrainStatus {
  DRAFT
  PENDING_REVIEW
  AVAILABLE
  RESERVED
  SOLD
  ARCHIVED
}

enum ProjectStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  ARCHIVED
}

enum CompatibilityStatus {
  SUGGESTED
  APPROVED
  REJECTED
}

enum SimulationStatus {
  DRAFT
  SENT
  CONVERTED
  EXPIRED
}

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  CANCELED
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  ASAAS
  MERCADO_PAGO
  MANUAL
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  CANCELED
  REFUNDED
}

enum ContractStatus {
  DRAFT
  PENDING_SIGNATURE
  SIGNED
  CANCELED
}

enum NotificationType {
  SYSTEM
  SALE
  PAYMENT
  CONTRACT
  COMPATIBILITY
}

enum Currency {
  BRL
  USD
}

enum NewsStatus {
  DRAFT
  PUBLISHED
}

model User {
  id               String     @id @default(cuid())
  name             String
  email            String     @unique
  passwordHash     String
  role             UserRole   @default(CUSTOMER)
  status           UserStatus @default(ACTIVE)
  phone            String?
  document         String?
  avatarUrl        String?
  refreshTokenHash String?
  emailVerifiedAt  DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  deletedAt        DateTime?

  architectProfile Architect?
  ownedTerrains    Terrain[]      @relation("TerrainOwner")
  simulations      Simulation[]   @relation("SimulationCustomer")
  orders           Order[]        @relation("CustomerOrders")
  favorites        Favorite[]
  notifications    Notification[]
  siteEvents       SiteEvent[]

  @@index([role])
  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

model Architect {
  id              String          @id @default(cuid())
  userId          String          @unique
  companyName     String?
  bio             String?
  cauNumber       String?         @unique
  website         String?
  status          ArchitectStatus @default(PENDING_REVIEW)
  rating          Decimal         @default(0) @db.Decimal(3, 2)
  revenueShare    Decimal         @default(0.70) @db.Decimal(5, 4)
  totalSales      Int             @default(0)
  reviewedAt      DateTime?
  reviewedById    String?
  rejectionReason String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]

  @@index([status])
  @@index([deletedAt])
  @@map("architects")
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

model SiteEvent {
  id        String   @id @default(cuid())
  userId    String?
  type      String
  path      String
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([type])
  @@index([path])
  @@index([createdAt])
  @@map("site_events")
}

model Terrain {
  id           String        @id @default(cuid())
  ownerId      String?
  title        String
  slug         String        @unique
  description  String
  address      String
  neighborhood String?
  city         String
  state        String
  country      String        @default("BR")
  zipCode      String?
  latitude     Decimal?      @db.Decimal(10, 7)
  longitude    Decimal?      @db.Decimal(10, 7)
  areaM2       Decimal       @db.Decimal(12, 2)
  frontageM    Decimal?      @db.Decimal(10, 2)
  depthM       Decimal?      @db.Decimal(10, 2)
  price        Decimal       @db.Decimal(14, 2)
  zoning       String?
  metadata     Json?
  status       TerrainStatus @default(DRAFT)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  owner           User?                  @relation("TerrainOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  images          TerrainImage[]
  compatibilities ProjectCompatibility[]
  simulations     Simulation[]
  orders          Order[]
  favorites       Favorite[]

  @@index([ownerId])
  @@index([city, state])
  @@index([neighborhood])
  @@index([status])
  @@index([price])
  @@index([areaM2])
  @@index([deletedAt])
  @@map("terrains")
}

model TerrainImage {
  id         String    @id @default(cuid())
  terrainId  String
  url        String
  storageKey String
  altText    String?
  sortOrder  Int       @default(0)
  isCover    Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  terrain Terrain @relation(fields: [terrainId], references: [id], onDelete: Cascade)

  @@index([terrainId])
  @@index([deletedAt])
  @@map("terrain_images")
}

model Project {
  id                 String        @id @default(cuid())
  architectId        String
  title              String
  slug               String        @unique
  description        String
  style              String?
  renderUrl          String?
  floorPlanUrl       String?
  bedrooms           Int
  bathrooms          Int
  suites             Int           @default(0)
  parkingSpaces      Int           @default(0)
  floors             Int           @default(1)
  areaM2             Decimal       @db.Decimal(12, 2)
  estimatedBuildCost Decimal       @db.Decimal(14, 2)
  price              Decimal       @db.Decimal(14, 2)
  status             ProjectStatus @default(DRAFT)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  deletedAt          DateTime?

  architect       Architect              @relation(fields: [architectId], references: [id], onDelete: Cascade)
  images          ProjectImage[]
  compatibilities ProjectCompatibility[]
  simulations     Simulation[]
  orders          Order[]
  favorites       Favorite[]

  @@index([architectId])
  @@index([status])
  @@index([price])
  @@index([areaM2])
  @@index([bedrooms])
  @@index([deletedAt])
  @@map("projects")
}

model ProjectImage {
  id         String    @id @default(cuid())
  projectId  String
  url        String
  storageKey String
  altText    String?
  sortOrder  Int       @default(0)
  isCover    Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([deletedAt])
  @@map("project_images")
}

model ProjectCompatibility {
  id        String              @id @default(cuid())
  terrainId String
  projectId String
  status    CompatibilityStatus @default(SUGGESTED)
  score     Decimal             @default(0) @db.Decimal(5, 2)
  notes     String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  deletedAt DateTime?

  terrain Terrain @relation(fields: [terrainId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([terrainId, projectId])
  @@index([status])
  @@index([deletedAt])
  @@map("project_compatibility")
}

model Simulation {
  id                 String           @id @default(cuid())
  customerId         String?
  terrainId          String?
  projectId          String?
  terrainPrice       Decimal          @db.Decimal(14, 2)
  projectPrice       Decimal          @db.Decimal(14, 2)
  estimatedBuildCost Decimal          @db.Decimal(14, 2)
  downPayment        Decimal          @default(0) @db.Decimal(14, 2)
  installmentCount   Int
  monthlyPayment     Decimal          @db.Decimal(14, 2)
  interestRate       Decimal          @db.Decimal(8, 4)
  totalAmount        Decimal          @db.Decimal(14, 2)
  status             SimulationStatus @default(DRAFT)
  metadata           Json?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  deletedAt          DateTime?

  customer User?    @relation("SimulationCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  terrain  Terrain? @relation(fields: [terrainId], references: [id], onDelete: SetNull)
  project  Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  orders   Order[]

  @@index([customerId])
  @@index([terrainId])
  @@index([projectId])
  @@index([status])
  @@index([deletedAt])
  @@map("simulations")
}

model Order {
  id           String      @id @default(cuid())
  customerId   String
  terrainId    String?
  projectId    String?
  simulationId String?
  subtotal     Decimal     @db.Decimal(14, 2)
  fees         Decimal     @default(0) @db.Decimal(14, 2)
  discount     Decimal     @default(0) @db.Decimal(14, 2)
  total        Decimal     @db.Decimal(14, 2)
  currency     Currency    @default(BRL)
  status       OrderStatus @default(DRAFT)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?

  customer   User        @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: Restrict)
  terrain    Terrain?    @relation(fields: [terrainId], references: [id], onDelete: SetNull)
  project    Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  simulation Simulation? @relation(fields: [simulationId], references: [id], onDelete: SetNull)
  payments   Payment[]
  contract   Contract?

  @@index([customerId])
  @@index([terrainId])
  @@index([projectId])
  @@index([simulationId])
  @@index([status])
  @@index([deletedAt])
  @@map("orders")
}

model Payment {
  id                String          @id @default(cuid())
  orderId           String
  provider          PaymentProvider
  status            PaymentStatus   @default(PENDING)
  amount            Decimal         @db.Decimal(14, 2)
  feeAmount         Decimal         @default(0) @db.Decimal(14, 2)
  providerPaymentId String?
  providerPayload   Json?
  splitPayload      Json?
  paidAt            DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([provider])
  @@index([status])
  @@index([providerPaymentId])
  @@index([deletedAt])
  @@map("payments")
}

model Contract {
  id         String         @id @default(cuid())
  orderId    String         @unique
  status     ContractStatus @default(DRAFT)
  url        String?
  storageKey String?
  signedAt   DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  deletedAt  DateTime?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([deletedAt])
  @@map("contracts")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  terrainId String?
  projectId String?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  terrain Terrain? @relation(fields: [terrainId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, terrainId])
  @@unique([userId, projectId])
  @@index([userId])
  @@map("favorites")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(SYSTEM)
  title     String
  body      String
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([readAt])
  @@index([deletedAt])
  @@map("notifications")
}

model NewsPost {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  excerpt     String
  content     String
  imageUrl    String?
  author      String?
  status      NewsStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  @@index([status, publishedAt])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("news_posts")
}
